rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profil fotoğrafları: profile_photos/{uid}.jpg
    match /profile_photos/{fileName} {
      // Giriş yapmış herkes profil fotoğrafını okuyabilir
      allow read: if request.auth != null;
      // Sadece kendi fotoğrafını yükleyebilir (dosya adı uid.jpg olmalı)
      allow write: if request.auth != null &&
        fileName == request.auth.uid + '.jpg' &&
        request.resource.size < 5 * 1024 * 1024 && // 5 MB limit
        request.resource.contentType.matches('image/.*');
    }

    // Diğer her şey erişilemez
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
